{
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node10",
    "target": "ES2022",
    "outDir": "./dist",
    "rootDir": "./src",
    "lib": ["ES2022"],
    "sourceMap": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "declaration": false,
    "types": ["vscode", "node"],
    "skipLibCheck": true
  },
  "include": [
    "src/extension.ts",
    "src/KanbanEditorProvider.ts",
    "src/messages.ts",
    "src/parser/index.ts",
    "src/parser/types.ts",
    "src/parser/parse.ts",
    "src/parser/serialize.ts"
  ],
  "exclude": ["src/parser/**/*.test.ts"]
}
